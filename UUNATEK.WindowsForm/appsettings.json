{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=UunatekPrinter;Trusted_Connection=true;MultipleActiveResultSets=true"
  },
  "Printer": {
    "ComPort": "COM5",
    "BaudRate": 250000
  },
  "ApprovalService": {
    "Endpoint": "https://future-approval-api.example.com/approve",
    "ApiKey": "",
    "TimeoutSeconds": 30,
    "UseMockService": true
  },
  "FileStorage": {
    "UploadPath": "uploads",
    "MaxImageSizeMB": 10,
    "MaxSvgSizeMB": 5
  },
  "PrintRetry": {
    "MaxRetries": 3,
    "RetryDelayMs": 1000
  }
}
