{
	"info": {
		"_postman_id": "uunatek-printer-api",
		"name": "UUNATEK Printer API",
		"description": "API for the UUNATEK handwriting pen plotter/printer. Endpoints mirror the WinForms app functionality.\n\n**Workflow:**\n1. Connect to printer\n2. Check status\n3. Generate G-code preview (optional)\n4. Print\n5. Disconnect",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:5000",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Connection",
			"item": [
				{
					"name": "Connect (default from appsettings)",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/printer/connect",
							"host": ["{{baseUrl}}"],
							"path": ["printer", "connect"]
						},
						"description": "Connect using COM port and baud rate from appsettings.json (default: COM5, 250000)."
					}
				},
				{
					"name": "Connect (custom port)",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/printer/connect?comPort=COM3&baudRate=250000",
							"host": ["{{baseUrl}}"],
							"path": ["printer", "connect"],
							"query": [
								{
									"key": "comPort",
									"value": "COM3",
									"description": "Serial port name (e.g. COM3, COM5)"
								},
								{
									"key": "baudRate",
									"value": "250000",
									"description": "Baud rate (default: 250000)"
								}
							]
						},
						"description": "Connect to a specific COM port, overriding appsettings."
					}
				},
				{
					"name": "Disconnect",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/printer/disconnect",
							"host": ["{{baseUrl}}"],
							"path": ["printer", "disconnect"]
						},
						"description": "Disconnect from the printer. Cannot disconnect while printing."
					}
				}
			]
		},
		{
			"name": "Status",
			"item": [
				{
					"name": "Get Status",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/printer/status",
							"host": ["{{baseUrl}}"],
							"path": ["printer", "status"]
						},
						"description": "Returns printer status: IsOpen, PortName, IsPrinting."
					}
				}
			]
		},
		{
			"name": "G-code Preview",
			"item": [
				{
					"name": "Generate G-code (with Paper enum)",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "svg",
									"type": "file",
									"src": "",
									"description": "SVG file to convert"
								},
								{
									"key": "Paper",
									"value": "A4",
									"type": "text",
									"description": "Paper size enum: A3, A4, A5, A6, B4, B5, Letter, Legal, Tabloid, Envelope_10, Envelope_9, Envelope_C5, Envelope_C6, Envelope_DL, Card_4x6, Card_5x7"
								},
								{
									"key": "XPosition",
									"value": "50mm",
									"type": "text",
									"description": "X offset on paper (default: 50mm)"
								},
								{
									"key": "YPosition",
									"value": "50mm",
									"type": "text",
									"description": "Y offset on paper (default: 50mm)"
								},
								{
									"key": "Scale",
									"value": "1",
									"type": "text",
									"description": "Scale multiplier, minimum 1"
								},
								{
									"key": "Rotation",
									"value": "0",
									"type": "text",
									"description": "Rotation in degrees (0-360)"
								},
								{
									"key": "InvertX",
									"value": "false",
									"type": "text",
									"description": "Mirror horizontally"
								},
								{
									"key": "InvertY",
									"value": "true",
									"type": "text",
									"description": "Mirror vertically (default: true)"
								}
							]
						},
						"url": {
							"raw": "{{baseUrl}}/printer/generate",
							"host": ["{{baseUrl}}"],
							"path": ["printer", "generate"]
						},
						"description": "Convert SVG to G-code without printing. Returns the G-code array for preview. Uses Paper enum to set Width/Height automatically."
					}
				},
				{
					"name": "Generate G-code (with custom dimensions)",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "svg",
									"type": "file",
									"src": "",
									"description": "SVG file to convert"
								},
								{
									"key": "Width",
									"value": "210mm",
									"type": "text",
									"description": "Paper width (default: 210mm)"
								},
								{
									"key": "Height",
									"value": "297mm",
									"type": "text",
									"description": "Paper height (default: 297mm)"
								},
								{
									"key": "XPosition",
									"value": "50mm",
									"type": "text",
									"description": "X offset on paper"
								},
								{
									"key": "YPosition",
									"value": "50mm",
									"type": "text",
									"description": "Y offset on paper"
								},
								{
									"key": "Scale",
									"value": "1",
									"type": "text",
									"description": "Scale multiplier, minimum 1"
								},
								{
									"key": "Rotation",
									"value": "0",
									"type": "text",
									"description": "Rotation in degrees (0-360)"
								},
								{
									"key": "InvertX",
									"value": "false",
									"type": "text",
									"description": "Mirror horizontally"
								},
								{
									"key": "InvertY",
									"value": "true",
									"type": "text",
									"description": "Mirror vertically"
								}
							]
						},
						"url": {
							"raw": "{{baseUrl}}/printer/generate",
							"host": ["{{baseUrl}}"],
							"path": ["printer", "generate"]
						},
						"description": "Convert SVG to G-code without printing. Uses custom Width/Height dimensions instead of Paper enum."
					}
				}
			]
		},
		{
			"name": "Print",
			"item": [
				{
					"name": "Print (single copy)",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "svg",
									"type": "file",
									"src": "",
									"description": "SVG file to print"
								},
								{
									"key": "Paper",
									"value": "A4",
									"type": "text",
									"description": "Paper size enum (overrides Width/Height)"
								},
								{
									"key": "XPosition",
									"value": "50mm",
									"type": "text",
									"description": "X offset on paper"
								},
								{
									"key": "YPosition",
									"value": "50mm",
									"type": "text",
									"description": "Y offset on paper"
								},
								{
									"key": "Scale",
									"value": "1",
									"type": "text",
									"description": "Scale multiplier, minimum 1"
								},
								{
									"key": "Rotation",
									"value": "0",
									"type": "text",
									"description": "Rotation in degrees (0-360)"
								},
								{
									"key": "InvertX",
									"value": "false",
									"type": "text",
									"description": "Mirror horizontally"
								},
								{
									"key": "InvertY",
									"value": "true",
									"type": "text",
									"description": "Mirror vertically"
								}
							]
						},
						"url": {
							"raw": "{{baseUrl}}/printer/print",
							"host": ["{{baseUrl}}"],
							"path": ["printer", "print"]
						},
						"description": "Convert SVG to G-code and send to printer. Requires connection first (POST /printer/connect)."
					}
				},
				{
					"name": "Print (bulk copies)",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "svg",
									"type": "file",
									"src": "",
									"description": "SVG file to print"
								},
								{
									"key": "copies",
									"value": "3",
									"type": "text",
									"description": "Number of copies (1-100)"
								},
								{
									"key": "Paper",
									"value": "A4",
									"type": "text",
									"description": "Paper size enum (overrides Width/Height)"
								},
								{
									"key": "XPosition",
									"value": "50mm",
									"type": "text",
									"description": "X offset on paper"
								},
								{
									"key": "YPosition",
									"value": "50mm",
									"type": "text",
									"description": "Y offset on paper"
								},
								{
									"key": "Scale",
									"value": "1",
									"type": "text",
									"description": "Scale multiplier, minimum 1"
								},
								{
									"key": "Rotation",
									"value": "0",
									"type": "text",
									"description": "Rotation in degrees (0-360)"
								},
								{
									"key": "InvertX",
									"value": "false",
									"type": "text",
									"description": "Mirror horizontally"
								},
								{
									"key": "InvertY",
									"value": "true",
									"type": "text",
									"description": "Mirror vertically"
								}
							]
						},
						"url": {
							"raw": "{{baseUrl}}/printer/print/bulk",
							"host": ["{{baseUrl}}"],
							"path": ["printer", "print", "bulk"]
						},
						"description": "Print multiple copies. Each copy does a full print cycle (paper ready handshake, print, eject)."
					}
				}
			]
		}
	]
}
