# Ignore build outputs
**/bin/
**/obj/
**/out/

# Ignore Visual Studio files
**/.vs/
**/.vscode/
*.user
*.suo
*.userprefs
*.sln.docstates

# Ignore git
.git/
.gitignore
.gitattributes

# Ignore documentation
*.md
**/*.md
*.doc
*.docx
DOCS_files/

# Ignore test files
**/test-*.txt
**/test-*.svg

# Ignore Windows-specific project
UUNATEK.WindowsForm/

# Ignore Postman collections
*.postman_collection.json

# Ignore sensitive files
**/.env
**/appsettings.Development.json
**/secrets.json

# Ignore Docker files themselves
Dockerfile*
docker-compose*
.dockerignore
